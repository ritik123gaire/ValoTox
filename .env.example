# ──────────────────────────────────────────────
# ValoTox Environment Configuration
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=ValoTox Research Dataset v1.0

# Twitter / X  (https://developer.twitter.com)
TWITTER_BEARER_TOKEN=your_bearer_token

# OpenAI (for GPT-4o synthetic annotator & agent)
OPENAI_API_KEY=sk-...

# Label Studio
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=your_label_studio_key

# LangSmith (optional observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT=valotox

# Model paths (populated after training)
MODEL_DIR=models/
BEST_MODEL=models/roberta-valotox/
